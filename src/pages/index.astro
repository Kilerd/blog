---
import Layout from '../components/Layout.astro'
import {
  formatSectionName,
  getArticlePosts,
  getExcerptHtml,
  getNavigationPages,
  getPostHref
} from '../lib/content'
import { getPublishedPosts } from '../lib/posts'
import { siteConfig } from '../lib/site'

const PAGE_SIZE = 10
const allPosts = await getPublishedPosts()
const posts = getArticlePosts(allPosts)
const pages = getNavigationPages(allPosts)
const rawPage = Astro.url.searchParams.get('page')
const parsedPage = rawPage ? Number.parseInt(rawPage, 10) : 1
const currentPage = Number.isFinite(parsedPage) && parsedPage > 0 ? parsedPage : 1
const totalPages = Math.max(1, Math.ceil(posts.length / PAGE_SIZE))

if (posts.length > 0 && currentPage > totalPages) {
  return new Response('Not Found', {
    status: 404,
    statusText: 'Not Found'
  })
}

const startIndex = (currentPage - 1) * PAGE_SIZE
const paginatedPosts = posts.slice(startIndex, startIndex + PAGE_SIZE)
const visiblePageCount = 5
const halfWindow = Math.floor(visiblePageCount / 2)
const windowStart = Math.max(1, Math.min(currentPage - halfWindow, totalPages - visiblePageCount + 1))
const windowEnd = Math.min(totalPages, windowStart + visiblePageCount - 1)
const pageNumbers = Array.from({ length: windowEnd - windowStart + 1 }, (_, index) => windowStart + index)
const canonicalPath = currentPage === 1 ? '/' : `/?page=${currentPage}`

function getPageHref(pageNumber: number) {
  return pageNumber === 1 ? '/' : `/?page=${pageNumber}`
}
---

<Layout showHeader={true} pages={pages} canonicalPath={canonicalPath}>
  <section class="mx-auto grid w-[min(1120px,calc(100%_-_32px))] gap-5 sm:w-[min(1120px,calc(100%_-_64px))]">
    <section class="rounded-lg border border-zinc-200 bg-white p-5 shadow-sm shadow-zinc-200/70 md:p-6">
      <div class="max-w-2xl">
        <p class="font-mono text-xs font-medium uppercase text-indigo-600">Latest writing</p>
        <h1 class="mt-2 text-3xl font-semibold leading-tight text-zinc-950 md:text-5xl">{siteConfig.title}</h1>
        <p class="mt-3 text-base leading-7 text-zinc-600 md:text-lg">{siteConfig.description}</p>
      </div>
    </section>

    {paginatedPosts.length > 0 && (
      <section class="grid gap-5">
        {paginatedPosts.map((post) => (
          <article class:list={[
            'group grid min-w-0 overflow-hidden rounded-lg border border-zinc-200 bg-white shadow-sm shadow-zinc-200/60 transition hover:border-zinc-300 hover:shadow-md hover:shadow-zinc-200/80',
            post.data.cover ? 'md:grid-cols-[240px_minmax(0,1fr)]' : 'md:grid-cols-1'
          ]}>
            {post.data.cover && (
              <a class="block h-36 border-b border-zinc-200 bg-zinc-100 md:h-auto md:self-stretch md:border-b-0 md:border-r" href={getPostHref(post)}>
                <img class="h-full w-full object-cover" src={post.data.cover} alt="" />
              </a>
            )}

            <div class="grid min-w-0 content-center gap-3 p-5 md:p-6">
              <div class="flex flex-wrap items-center gap-2 font-mono text-xs text-zinc-500">
                <span class="inline-flex min-h-6 items-center rounded-full border border-indigo-200 bg-indigo-50 px-2 text-indigo-700">{formatSectionName(post.data.section)}</span>
                <time>{new Date(post.data.publishedAt).toLocaleDateString('en-US', { month: '2-digit', day: '2-digit', year: 'numeric' })}</time>
              </div>
              <a class="break-words text-2xl font-semibold leading-tight text-zinc-950 no-underline transition group-hover:text-indigo-600" href={getPostHref(post)}>{post.title}</a>
              {post.data.excerpt && (
                <section
                  class="prose prose-zinc max-w-none text-zinc-600 prose-p:my-0 prose-ul:my-0 prose-li:my-0"
                  set:html={getExcerptHtml(post)}
                />
              )}
            </div>
          </article>
        ))}
      </section>
    )}

    {totalPages > 1 && (
      <nav class="flex flex-col gap-3 pt-2 md:flex-row md:items-center md:justify-between" aria-label="Homepage pagination">
        <a
          class:list={[
            'inline-flex min-h-10 items-center justify-center rounded-lg border border-zinc-200 bg-white px-4 text-sm font-medium text-zinc-700 no-underline transition hover:border-zinc-300 hover:text-zinc-950',
            currentPage === 1 && 'pointer-events-none opacity-45'
          ]}
          href={currentPage === 1 ? undefined : getPageHref(currentPage - 1)}
          aria-disabled={currentPage === 1}
        >
          Previous
        </a>

        <div class="flex flex-wrap items-center gap-2">
          {pageNumbers.map((pageNumber) => (
            <a
              class:list={[
                'inline-flex min-h-10 min-w-10 items-center justify-center rounded-lg border border-zinc-200 bg-white px-3 text-sm font-medium text-zinc-700 no-underline transition hover:border-zinc-300 hover:text-zinc-950',
                pageNumber === currentPage && 'border-indigo-200 bg-indigo-50 text-indigo-700'
              ]}
              href={getPageHref(pageNumber)}
              aria-current={pageNumber === currentPage ? 'page' : undefined}
            >
              {pageNumber}
            </a>
          ))}
        </div>

        <a
          class:list={[
            'inline-flex min-h-10 items-center justify-center rounded-lg border border-zinc-200 bg-white px-4 text-sm font-medium text-zinc-700 no-underline transition hover:border-zinc-300 hover:text-zinc-950',
            currentPage === totalPages && 'pointer-events-none opacity-45'
          ]}
          href={currentPage === totalPages ? undefined : getPageHref(currentPage + 1)}
          aria-disabled={currentPage === totalPages}
        >
          Next
        </a>
      </nav>
    )}
  </section>
</Layout>
