---
export const prerender = false

import Comments from '../components/Comments.astro'
import Layout from '../components/Layout.astro'
import { findPostByPath, formatSectionName, getDescription, getNavigationPages } from '../lib/content'
import { renderMarkdownToHtml } from '../lib/markdown'
import { getPublishedPosts } from '../lib/posts'

const allPosts = await getPublishedPosts()
const pages = getNavigationPages(allPosts)
const currentPath = Astro.params.slug ?? ''
const post = findPostByPath(allPosts, currentPath)

if (!post) {
  return new Response('Not Found', {
    status: 404,
    statusText: 'Not Found'
  })
}

const contentHtml = renderMarkdownToHtml(post.data.content)
const description = getDescription(post)
const canonicalPath = `/${post.data.path}`
---

<Layout
  title={post.title}
  description={description}
  pages={pages}
  canonicalPath={canonicalPath}
  ogType="article"
>
  <section class="mx-auto grid w-[min(1120px,calc(100%_-_32px))] gap-5 sm:w-[min(1120px,calc(100%_-_64px))]">
    <section class="min-w-0 rounded-lg border border-zinc-200 bg-white p-5 shadow-sm shadow-zinc-200/70 md:p-8">
      <p class="inline-flex min-h-6 items-center rounded-full border border-indigo-200 bg-indigo-50 px-2 font-mono text-xs font-medium uppercase text-indigo-700">
        {formatSectionName(post.data.section)}
      </p>
      {post.data.cover && <img class="mt-5 w-full rounded-lg border border-zinc-200 bg-zinc-100" src={post.data.cover} alt="" />}
      <h1 class="mt-5 break-words text-3xl font-semibold leading-tight text-zinc-950 md:text-5xl">{post.title}</h1>
      <p class="mt-3 font-mono text-sm text-zinc-500">
        {new Date(post.data.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </p>
      <section
        class="prose prose-zinc mt-8 min-w-0 max-w-none break-words prose-headings:font-semibold prose-headings:tracking-normal prose-a:text-indigo-600 prose-a:no-underline hover:prose-a:text-indigo-500 prose-blockquote:rounded-lg prose-blockquote:border prose-blockquote:border-zinc-200 prose-blockquote:bg-zinc-50 prose-blockquote:px-4 prose-blockquote:py-3 prose-blockquote:not-italic prose-code:break-words prose-code:rounded prose-code:bg-zinc-100 prose-code:px-1 prose-code:py-0.5 prose-code:text-zinc-900 prose-code:before:content-none prose-code:after:content-none prose-pre:max-w-full prose-pre:overflow-x-auto prose-pre:rounded-lg prose-pre:border prose-pre:border-zinc-200 prose-pre:bg-zinc-950 prose-img:max-w-full prose-img:rounded-lg prose-img:border prose-img:border-zinc-200 prose-th:bg-zinc-50"
      >
        <Fragment set:html={contentHtml} />
        <script
          is:inline
          async
          src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9147137464451642"
          crossorigin="anonymous"></script>
        <ins
          class="adsbygoogle"
          style="display:block"
          data-ad-client="ca-pub-9147137464451642"
          data-ad-slot="6925468905"
          data-ad-format="auto"
          data-full-width-responsive="true"></ins>
        <script is:inline>
          (adsbygoogle = window.adsbygoogle || []).push({});
        </script>
      </section>
    </section>
    <section class="min-w-0 rounded-lg border border-zinc-200 bg-white p-5 shadow-sm shadow-zinc-200/70 md:p-6">
      <Comments issueId={canonicalPath} issueTitle={post.title} />
    </section>
  </section>
</Layout>
