---
import Comments from '../components/Comments.astro'
import Layout from '../components/Layout.astro'
import { getNavigationPages } from '../lib/content'
import { getPublishedPosts } from '../lib/posts'

const allPosts = await getPublishedPosts()
const pages = getNavigationPages(allPosts)
const title = 'PORTFOLIOS'
const publishedAt = '2026-05-10T00:00:00+09:00'
const description = 'Kilerd 做过的产品、工具与长期作品合集。'
const githubLogo = 'https://github.githubassets.com/images/modules/logos_page/GitHub-Mark.png'

const latestProjects = [
  {
    name: 'AnyStorage',
    href: 'https://anystorage.dev/',
    logo: 'https://anystorage.dev/anystorage-logo.png',
    logoAlt: 'AnyStorage logo',
    summary:
      '一个桌面端存储工作台，把分散在不同云服务里的文件、资源和连接整理到同一个地方。适合需要频繁交付文件、维护资源的小团队与个人开发者。'
  },
  {
    name: 'Onsei',
    href: 'https://www.on-sei.com/',
    logo: 'https://www.on-sei.com/logo.svg',
    logoAlt: 'Onsei logo',
    summary:
      '一个日语学习应用，把词汇和语法复习放进更轻、更稳定的日常节奏里。它不追求把学习做成闯关游戏，更像是一张安静的书桌。'
  }
]

const archiveProjects = [
  {
    name: 'Zhang',
    href: 'https://github.com/zhang-accounting/zhang',
    logo: githubLogo,
    logoAlt: 'GitHub logo',
    summary:
      '给认真管理个人财务的人用的账本工具。它强调清晰、可追溯和长期维护，也尝试让日常录入、查看和移动端使用更顺手。'
  },
  {
    name: 'rubble',
    href: 'https://github.com/Kilerd/rubble',
    logo: githubLogo,
    logoAlt: 'GitHub logo',
    summary:
      '早期写过的一套个人发布系统。它承载的是对写作工具的第一轮探索：把文章、页面和后台放进一个自己可控的地方。'
  }
]

const projects = [...latestProjects, ...archiveProjects]
---

<Layout title={title} description={description} pages={pages} canonicalPath="/portfolios" ogType="website">
  <section class="mx-auto grid w-[min(1120px,calc(100%_-_32px))] gap-5 sm:w-[min(1120px,calc(100%_-_64px))]">
    <section class="min-w-0 rounded-lg border border-zinc-200 bg-white p-5 shadow-sm shadow-zinc-200/70 md:p-8">
      <p class="inline-flex min-h-6 items-center rounded-full border border-indigo-200 bg-indigo-50 px-2 font-mono text-xs font-medium uppercase text-indigo-700">
        Page
      </p>
      <h1 class="mt-5 break-words text-3xl font-semibold leading-tight text-zinc-950 md:text-5xl">
        PORTFOLIOS
      </h1>
      <p class="mt-3 font-mono text-sm text-zinc-500">
        {new Date(publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </p>

      <section class="prose prose-zinc mt-8 min-w-0 max-w-none break-words prose-headings:font-semibold prose-headings:tracking-normal prose-a:text-indigo-600 prose-a:no-underline hover:prose-a:text-indigo-500">
        <p>这些是我正在做、曾经做过，或者仍然觉得值得留下来的项目。</p>
      </section>

      <section class="mt-5 grid gap-4">
        {projects.map((project) => (
          <article class="flex min-w-0 flex-col gap-4 rounded-lg border border-zinc-200 bg-zinc-50 p-4 sm:flex-row sm:items-start">
            <a
              class="grid h-16 w-16 shrink-0 place-items-center overflow-hidden rounded-lg bg-white p-2 no-underline shadow-sm shadow-zinc-200/60"
              href={project.href}
              target="_blank"
              rel="noreferrer"
            >
              <img class="h-full w-full object-contain" src={project.logo} alt={project.logoAlt} loading="lazy" />
            </a>
            <div class="min-w-0">
              <h3 class="break-words text-xl font-semibold leading-tight text-zinc-950">
                <a class="text-indigo-600 no-underline transition hover:text-indigo-500" href={project.href} target="_blank" rel="noreferrer">
                  {project.name}
                </a>
              </h3>
              <p class="mt-2 text-sm leading-7 text-zinc-600 md:text-base md:leading-8">{project.summary}</p>
            </div>
          </article>
        ))}
      </section>
    </section>
    <section class="min-w-0 rounded-lg border border-zinc-200 bg-white p-5 shadow-sm shadow-zinc-200/70 md:p-6">
      <Comments issueId="/portfolios" issueTitle={title} />
    </section>
  </section>
</Layout>
