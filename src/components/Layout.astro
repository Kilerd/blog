---
import '../styles/global.css'
import { absoluteUrl, siteConfig } from '../lib/site'
import type { PostRecord } from '../lib/posts'

interface Props {
  title?: string
  description?: string
  pages?: PostRecord[]
  showHeader?: boolean
  canonicalPath?: string
  ogType?: 'website' | 'article'
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  pages = [],
  showHeader = false,
  canonicalPath = '/',
  ogType = 'website'
} = Astro.props

const isHome = showHeader
const navLinkClass =
  'inline-flex min-h-9 items-center rounded-lg border border-transparent px-3 text-sm font-medium text-zinc-600 transition hover:border-zinc-200 hover:bg-white hover:text-zinc-950'
---

<!doctype html>
<html lang="zh-Hans" class="han-init">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <meta name="keywords" content={siteConfig.keywords.join(', ')} />
    <meta name="description" content={description} />
    <meta name="monetag" content={siteConfig.monetag} />
    <meta name="google-adsense-account" content={siteConfig.adsenseAccount} />
    <meta property="og:site_name" content={siteConfig.title} />
    <meta property="og:url" content={absoluteUrl(canonicalPath)} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <link rel="canonical" href={absoluteUrl(canonicalPath)} />
    <link rel="alternate" type="application/rss+xml" title={siteConfig.title} href="/rss.xml" />
    <link rel="stylesheet" href="/vendors/han/han.layer.css" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-zinc-50 font-sans text-zinc-950 antialiased">
    <header class="sticky top-0 z-20 border-b border-zinc-200/80 bg-zinc-50/90 backdrop-blur-xl">
      <section class="mx-auto w-[min(1120px,calc(100%_-_32px))] sm:w-[min(1120px,calc(100%_-_64px))]">
        <div class="flex min-h-16 flex-col justify-center gap-3 py-3 md:flex-row md:items-center md:justify-between md:py-0">
          <a class="inline-flex w-fit items-center text-zinc-950 no-underline" href="/">
            <strong class="text-[15px] font-semibold leading-5">{siteConfig.title}</strong>
          </a>

          <nav class="flex flex-wrap items-center gap-1">
            <a
              class:list={[
                navLinkClass,
                isHome && 'border-indigo-200 bg-white text-zinc-950 shadow-sm shadow-zinc-200/70'
              ]}
              href="/"
            >
              Blog
            </a>
            {pages.map((page) => (
              <a class={navLinkClass} href={`/${page.data.path}`}>{page.title}</a>
            ))}
            <a class={navLinkClass} href="/rss.xml">RSS</a>
          </nav>
        </div>
      </section>
    </header>

    <main class="py-8 md:py-12">
      <slot />
    </main>

    <footer class="border-t border-zinc-200 bg-zinc-50 py-10">
      <section class="mx-auto w-[min(1120px,calc(100%_-_32px))] text-center text-xs text-zinc-500 sm:w-[min(1120px,calc(100%_-_64px))]">
        <p class="[&_a]:font-medium [&_a]:text-zinc-700 [&_a]:no-underline hover:[&_a]:text-indigo-600">
          自豪地使用 <a href="https://keystatic.com">Keystatic</a> 与 <a href="https://astro.build">Astro</a> 运行。
        </p>
      </section>
    </footer>

    <script is:inline defer src="/vendors/han/han.min.js"></script>
    <script is:inline src="/statics/prism.js" type="text/javascript"></script>
    <script is:inline defer src={siteConfig.umamiSrc} data-website-id={siteConfig.umamiWebsiteId}></script>
  </body>
</html>
