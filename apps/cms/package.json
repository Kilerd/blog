{
  "name": "@kilerd/cms",
  "version": "0.1.0",
  "private": true,
  "description": "SonicJS CMS for the kilerd blog",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply DB",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@sonicjs-cms/core": "^2.8.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251202.0",
    "@types/node": "^24.10.1",
    "drizzle-kit": "^0.31.7",
    "drizzle-orm": "^0.44.7",
    "hono": "^4.10.7",
    "typescript": "^5.9.3",
    "wrangler": "^4.52.1",
    "zod": "^4.1.13"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
