---
import Layout from '../components/Layout.astro'
import {
  formatSectionName,
  getArticlePosts,
  getExcerptHtml,
  getNavigationPages,
  getPostHref
} from '../lib/content'
import { getPublishedPosts } from '../lib/sonic'

const PAGE_SIZE = 10
const allPosts = await getPublishedPosts()
const posts = getArticlePosts(allPosts)
const pages = getNavigationPages(allPosts)
const rawPage = Astro.url.searchParams.get('page')
const parsedPage = rawPage ? Number.parseInt(rawPage, 10) : 1
const currentPage = Number.isFinite(parsedPage) && parsedPage > 0 ? parsedPage : 1
const totalPages = Math.max(1, Math.ceil(posts.length / PAGE_SIZE))

if (posts.length > 0 && currentPage > totalPages) {
  return new Response('Not Found', {
    status: 404,
    statusText: 'Not Found'
  })
}

const startIndex = (currentPage - 1) * PAGE_SIZE
const paginatedPosts = posts.slice(startIndex, startIndex + PAGE_SIZE)
const visiblePageCount = 5
const halfWindow = Math.floor(visiblePageCount / 2)
const windowStart = Math.max(1, Math.min(currentPage - halfWindow, totalPages - visiblePageCount + 1))
const windowEnd = Math.min(totalPages, windowStart + visiblePageCount - 1)
const pageNumbers = Array.from({ length: windowEnd - windowStart + 1 }, (_, index) => windowStart + index)
const canonicalPath = currentPage === 1 ? '/' : `/?page=${currentPage}`

function getPageHref(pageNumber: number) {
  return pageNumber === 1 ? '/' : `/?page=${pageNumber}`
}
---

<Layout showHeader={true} pages={pages} canonicalPath={canonicalPath}>
  <section class="container home-shell">
    {paginatedPosts.length > 0 && (
      <section class="story-list">
        {paginatedPosts.map((post) => (
          <article class:list={['post-row', !post.data.cover && 'post-row-text-only']}>
            {post.data.cover && (
              <a class="post-row-media" href={getPostHref(post)}>
                <img src={post.data.cover} alt="" />
              </a>
            )}

            <div class="post-row-body">
              <div class="meta-row">
                <span class="section-pill">{formatSectionName(post.data.section)}</span>
                <time>{new Date(post.data.publishedAt).toLocaleDateString('en-US', { month: '2-digit', day: '2-digit', year: 'numeric' })}</time>
              </div>
              <a class="post-row-title" href={getPostHref(post)}>{post.title}</a>
              {post.data.excerpt && <section class="yue desc" set:html={getExcerptHtml(post)} />}
            </div>
          </article>
        ))}
      </section>
    )}

    {totalPages > 1 && (
      <nav class="pagination" aria-label="Homepage pagination">
        <a
          class:list={['pagination-link', currentPage === 1 && 'is-disabled']}
          href={currentPage === 1 ? undefined : getPageHref(currentPage - 1)}
          aria-disabled={currentPage === 1}
        >
          Previous
        </a>

        <div class="pagination-pages">
          {pageNumbers.map((pageNumber) => (
            <a
              class:list={['pagination-link', 'pagination-number', pageNumber === currentPage && 'is-current']}
              href={getPageHref(pageNumber)}
              aria-current={pageNumber === currentPage ? 'page' : undefined}
            >
              {pageNumber}
            </a>
          ))}
        </div>

        <a
          class:list={['pagination-link', currentPage === totalPages && 'is-disabled']}
          href={currentPage === totalPages ? undefined : getPageHref(currentPage + 1)}
          aria-disabled={currentPage === totalPages}
        >
          Next
        </a>
      </nav>
    )}
  </section>
</Layout>
